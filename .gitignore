# ── Claude Code runtime state ────────────────────────────────────────────────
# Top-level .claude/ (user's Claude Code state for this repo)
.claude/.claude.json
.claude/backups/
.claude/cache/
.claude/debug/
.claude/file-history/
.claude/history.jsonl
.claude/mcp-needs-auth-cache.json
.claude/paste-cache/
.claude/plans/
.claude/plugins/
.claude/projects/
.claude/session-env/
.claude/sessions/
.claude/settings.local.json
.claude/shell-snapshots/
.claude/stats-cache.json
.claude/tasks/
.claude/telemetry/
.claude/todos/
.claude/skills/  # symlinks to shared skills

# Per-role .claude/ runtime (generated per role)
roles/*/.claude/.claude.json
roles/*/.claude/backups/
roles/*/.claude/cache/
roles/*/.claude/debug/
roles/*/.claude/file-history/
roles/*/.claude/history.jsonl
roles/*/.claude/mcp-needs-auth-cache.json
roles/*/.claude/paste-cache/
roles/*/.claude/plans/
roles/*/.claude/plugins/
roles/*/.claude/projects/
roles/*/.claude/session-env/
roles/*/.claude/sessions/
roles/*/.claude/settings.local.json
roles/*/.claude/shell-snapshots/
roles/*/.claude/stats-cache.json
roles/*/.claude/tasks/
roles/*/.claude/telemetry/
roles/*/.claude/todos/

# ── Runtime state (lives in project's .octobots/, not in framework) ─────────
# .octobots/ is created per-project by init-project.sh

# ── Secrets ─────────────────────────────────────────────────────────────────
*.pem
.gh-token-cache

# ── Taskbox database (runtime, recreated on init) ───────────────────────────
*.db
*.db-wal
*.db-shm

# ── Worktrees (temporary, per-task) ─────────────────────────────────────────
.worktrees/

# ── Generated project config (lives in target project, not octonauts) ───────
.octonauts/

# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# ── Node ────────────────────────────────────────────────────────────────────
node_modules/

# ── Environment & secrets ──────────────────────────────────────────────────
.env
.env.*
.mcp.json

# ── Handoff (contains tokens/paths) ─────────────────────────────────────────
handoff-before-clear.md

# ── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ─────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.elitea
.playwright-mcp/
.octobots/
.claude/image-cache/

# ── What IS tracked ─────────────────────────────────────────────────────────
# roles/*/SOUL.md        — personality (versioned)
# roles/*/CLAUDE.md      — instructions (versioned)
# roles/*/MEMORY.md      — persistent learnings (versioned)
# roles/*/.claude/skills/ — symlinks to shared skills (versioned)
# roles/*/.claude/agents/ — symlinks to shared agents (versioned)
# skills/*/               — skill definitions (versioned)
# shared/                 — conventions + shared agents (versioned)
